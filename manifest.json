{
  "api_version": "3.0",
  "name": "Raindrop v2.4.1",
  "authors": "Bruno Paz",
  "version": "2.4.1",
  "icon": "images/icon.png",
  "instructions": "This extension requires a Raindrop.io account. Create an access token at https://app.raindrop.io/settings/integrations and set it in the extension preferences.",
  "input_debounce": 0.4,
  "triggers": {
    "kw_open": {
      "name": "Raindrop: Open In browser",
      "default_keyword": "rdopen"
    },
    "kw_unsorted": {
      "name": "Raindrop: Unsorted",
      "default_keyword": "rd:unsorted"
    },
    "kw_tag": {
      "name": "Raindrop: Search by Tag",
      "default_keyword": "rd:tag"
    },
    "kw": {
      "name": "Raindrop: Search",
      "default_keyword": "rd"
    }
  },
  "preferences": [
    {
      "id": "access_token",
      "type": "input",
      "name": "Raindrop Access Token"
    },
    {
      "id": "show_favicons",
      "type": "checkbox",
      "name": "Show Favicons (requires restart)",
      "default_value": true
    }
  ]
}